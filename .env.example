# LLM driver: "anthropic", "openai", "mokksy" (mock server), or "mock" (built-in canned responses)
LLM_DRIVER=anthropic

# Anthropic (required for "anthropic" / "mokksy" driver)
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (required for "openai" driver)
# OPENAI_API_KEY=your-openai-key-here
# OPENAI_MODEL=gpt-4o

# Required for "mokksy" driver — URL of your running Mokksy server
# ANTHROPIC_BASE_URL=http://localhost:8080

PASS_THRESHOLD=3.5
MAX_TURNS=3
